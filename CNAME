<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="LwendGo - Premium Traveling and Transport Agency. Book your journey with us.">
    <meta name="theme-color" content="#0066CC">
    <title>LwendGo - Traveling & Transport Agency</title>
    <link rel="stylesheet" href="css/styles.css">
    <link rel="stylesheet" href="css/responsive.css">
    <link rel="icon" href="images/favicon.ico" type="image/x-icon">
</head>
<body>
    <!-- Navigation -->
    <nav class="navbar">
        <div class="container">
            <div class="logo">
                <img src="images/logo.png" alt="LwendGo Logo">
                <h1>LwendGo</h1>
            </div>
            <ul class="nav-links">
                <li><a href="#home">Home</a></li>
                <li><a href="#services">Services</a></li>
                <li><a href="#about">About</a></li>
                <li><a href="#contact">Contact</a></li>
            </ul>
        </div>
    </nav>

    <!-- Hero Section -->
    <section id="home" class="hero">
        <div class="hero-content">
            <h2>Your Journey, Our Passion</h2>
            <p>Experience Premium Travel & Transport Services</p>
            <button class="cta-button">Book Now</button>
        </div>
    </section>

    <!-- Services Section -->
    <section id="services" class="services">
        <div class="container">
            <h2>Our Services</h2>
            <div class="service-grid">
                <div class="service-card">
                    <img src="images/icons/bus.svg" alt="Bus Tours">
                    <h3>Bus Tours</h3>
                    <p>Comfortable and affordable bus travel across the region</p>
                </div>
                <div class="service-card">
                    <img src="images/icons/car.svg" alt="Car Rentals">
                    <h3>Car Rentals</h3>
                    <p>Premium vehicles for your personal travel needs</p>
                </div>
                <div class="service-card">
                    <img src="images/icons/hotel.svg" alt="Hotel Bookings">
                    <h3>Hotel Bookings</h3>
                    <p>Curated accommodation options for your stay</p>
                </div>
                <div class="service-card">
                    <img src="images/icons/package.svg" alt="Tour Packages">
                    <h3>Tour Packages</h3>
                    <p>All-inclusive travel packages to exotic destinations</p>
                </div>
            </div>
        </div>
    </section>

    <!-- About Section -->
    <section id="about" class="about">
        <div class="container">
            <h2>About LwendGo</h2>
            <p>Founded with a mission to revolutionize travel and transport services, LwendGo has been serving customers with excellence for over a decade. We combine reliability, comfort, and affordability in every journey.</p>
        </div>
    </section>

    <!-- Contact Section -->
    <section id="contact" class="contact">
        <div class="container">
            <h2>Get In Touch</h2>
            <form class="contact-form">
                <input type="text" placeholder="Your Name" required>
                <input type="email" placeholder="Your Email" required>
                <textarea placeholder="Your Message" rows="5" required></textarea>
                <button type="submit" class="cta-button">Send Message</button>
            </form>
        </div>
    </section>

    <!-- Footer -->
    <footer>
        <div class="container">
            <p>&copy; 2026 LwendGo Traveling & Transport Agency. All rights reserved.</p>
            <div class="social-links">
                <a href="#">Facebook</a>
                <a href="#">Twitter</a>
                <a href="#">Instagram</a>
            </div>
        </div>
    </footer>

    <script src="js/main.js"></script>
</body>
</html>

